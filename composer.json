{
    "name": "larawave/logic-as-data",
    "description": "Treat your business logic as data with this dynamic, data-driven engine for Laravel.",
    "keywords": [
        "laravel",
        "logic-engine",
        "business-rules",
        "rule-engine",
        "ast",
        "logic-as-data",
        "workflow-automation",
        "conditional-logic",
        "json-rules"
    ],
    "homepage": "https://github.com/LaraWave/logic-as-data",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Tushar Kadus",
            "email": "tushar.kadus9@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "LaraWave\\LogicAsData\\": "src/",
            "LaraWave\\LogicAsData\\Database\\Factories\\": "database/factories/",
            "LaraWave\\LogicAsData\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaraWave\\LogicAsData\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaraWave\\LogicAsData\\LogicAsDataCoreServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
